<Window x:Class="AIO_Hybrid_Clipboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIO_Hybrid_Clipboard"
        xmlns:conv="clr-namespace:AIO_Hybrid_Clipboard.Converters"
        mc:Ignorable="d"
        Title="AIO Hybrid Clipboard" SizeToContent="Height" Width="1000" MinHeight="170"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">

    <Window.Resources>
        <conv:EditSelectionToVisibilityConverter x:Key="EditSelToVis"/>
        <conv:QuickPasteBadgeConverter x:Key="IdxBadge"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" Background="Transparent" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#D9000000" CornerRadius="3" BorderBrush="#333333" BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Grid>
                            <Border x:Name="Bd" Background="Transparent" BorderBrush="Transparent" BorderThickness="2" CornerRadius="11" Padding="0">
                                <ContentPresenter/>
                            </Border>
                            <!-- Edit-mode selection checkmark, top-right corner -->
                            <Border Width="22" Height="22" CornerRadius="11"
                                    Background="#5865F2" BorderBrush="White" BorderThickness="1.5"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,6,2"
                                    IsHitTestVisible="False">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource EditSelToVis}">
                                        <Binding Path="IsSelected"    RelativeSource="{RelativeSource AncestorType={x:Type ListBoxItem}}"/>
                                        <Binding Path="SelectionMode" RelativeSource="{RelativeSource AncestorType={x:Type ListBox}}"/>
                                    </MultiBinding>
                                </Border.Visibility>
                                <TextBlock Text="✓" Foreground="White" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5865F2"/>
                                <Setter TargetName="Bd" Property="Background" Value="#225865F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="#F218191C"/>
            <Setter Property="BorderBrush" Value="#2F3136"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="150"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <StackPanel IsItemsHost="True" Margin="0,5,0,5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="#B9BBBE"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="18,8,18,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="ItemContainer" CornerRadius="5" Margin="5,1,5,1" Background="Transparent" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemContainer" Property="Background" Value="#4F545C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="DiscordTrayMenu" Style="{StaticResource TrayContextMenuStyle}">
            <MenuItem Header="{Binding Loc[TrayOpen]}" Style="{StaticResource TrayMenuItemStyle}" Click="TrayMenu_Open_Click"/>
            <MenuItem Header="{Binding Loc[TrayExit]}" Style="{StaticResource TrayMenuItemStyle}" Click="TrayMenu_Close_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="105"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10,5,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="45"/>
                <ColumnDefinition Width="42"/>
                <ColumnDefinition Width="45"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#D92D2D2D" CornerRadius="15" Margin="4" BorderBrush="#444444" BorderThickness="1">
                <TextBox Name="TxtSearch" Background="Transparent" Foreground="White"
                         BorderThickness="0" FontSize="16" Padding="12,8,12,8"
                         CaretBrush="White" VerticalAlignment="Center"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="TxtSearch_PreviewKeyDown"/>
            </Border>

            <CheckBox Grid.Column="1" Name="ChkEdit" Margin="4"
                      IsChecked="{Binding IsEditMode}"
                      Checked="ChkEdit_Checked" Unchecked="ChkEdit_Unchecked"
                      ToolTip="Toggle edit mode for multi-select"
                      VerticalAlignment="Stretch">
                <CheckBox.Template>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" Background="#D92D2D2D" CornerRadius="12"
                                BorderBrush="#444444" BorderThickness="1" Cursor="Hand">
                            <TextBlock Text="✏" FontSize="17" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CC5865F2"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7289DA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7289DA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </CheckBox.Template>
            </CheckBox>

            <Button Grid.Column="2" Name="BtnDelete" Click="BtnDelete_Click" Margin="4"
                    Background="#D92D2D2D" BorderBrush="#444444" BorderThickness="1" Foreground="White"
                    ToolTip="Delete selected items">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
                <TextBlock Text="🗑" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <Button Grid.Column="3" Name="BtnSettings" Click="BtnSettings_Click" Margin="4" Background="#D92D2D2D" BorderBrush="#444444" BorderThickness="1" Foreground="White"
                    ToolTip="Open settings">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                    </Style>
                </Button.Resources>
                <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#D9252525" CornerRadius="15" Margin="4" BorderBrush="#444444" BorderThickness="1">
                <ListBox Name="LstResults" ItemsSource="{Binding TextsView}"
                         PreviewMouseWheel="ListBox_PreviewMouseWheel" AlternationCount="15">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,0,4,0">
                                <Border Background="#D9333333" CornerRadius="10" Padding="12,8,12,8" BorderBrush="#555555" BorderThickness="1"
                                        PreviewMouseLeftButtonDown="ResultItem_PreviewMouseLeftButtonDown"
                                        MouseRightButtonUp="ResultItem_TogglePin" Cursor="Hand">

                                    <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" MaxWidth="180" TextTrimming="CharacterEllipsis"
                                               ToolTipService.InitialShowDelay="50"
                                               ToolTipService.BetweenShowDelay="0"
                                               ToolTipService.ShowDuration="60000">
                                        <TextBlock.ToolTip>
                                            <ToolTip Background="Transparent" BorderThickness="0" Padding="0">
                                                <Border Background="#F218191C" CornerRadius="8" BorderBrush="#2F3136" BorderThickness="1" Padding="12,10">
                                                    <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" MaxWidth="400" FontSize="13"/>
                                                </Border>
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </Border>

                                <!-- Quick-paste number badge (Alt+1/2/3), first three items only -->
                                <Border Width="17" Height="17" CornerRadius="8.5" Background="#CC5865F2"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,-2"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Converter={StaticResource IdxBadge}, ConverterParameter=vis}">
                                    <TextBlock Foreground="White" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Converter={StaticResource IdxBadge}}"/>
                                </Border>

                                <!-- Pin indicator (bottom-right to avoid the edit-mode check badge) -->
                                <TextBlock Text="📌" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,-2"
                                           IsHitTestVisible="False"
                                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Background="#D9252525" CornerRadius="15" Margin="4" BorderBrush="#444444" BorderThickness="1">
                <ListBox Name="LstScreenshots" ItemsSource="{Binding ScreenshotsView}"
                         PreviewMouseWheel="ListBox_PreviewMouseWheel">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#555555" BorderThickness="1" CornerRadius="8" Margin="4,0,4,0" Background="#111111" ClipToBounds="True" Padding="1"
                                    PreviewMouseLeftButtonDown="Screenshot_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="Screenshot_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="Screenshot_PreviewMouseLeftButtonUp"
                                    MouseRightButtonUp="Screenshot_TogglePin"
                                    Cursor="Hand"
                                    ToolTipService.InitialShowDelay="350" ToolTipService.ShowDuration="60000">
                                <Border.ToolTip>
                                    <ToolTip Background="Transparent" BorderThickness="0" Padding="0">
                                        <Border Background="#F218191C" CornerRadius="10" BorderBrush="#2F3136" BorderThickness="1" Padding="6">
                                            <StackPanel>
                                                <Image Source="{Binding Image}" MaxWidth="480" MaxHeight="340" Stretch="Uniform"/>
                                                <TextBlock Text="{Binding Name}" Foreground="#B9BBBE" FontSize="11"
                                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Grid>
                                    <Image Source="{Binding Image}" Width="110" Height="65" Stretch="UniformToFill"/>
                                    <!-- Pin indicator -->
                                    <Border Background="#B2000000" CornerRadius="9" Width="18" Height="18"
                                            HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2"
                                            IsHitTestVisible="False"
                                            Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="📌" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Row="2" Name="PnlSettingsDrawer" Visibility="Collapsed" Background="#E6222222" CornerRadius="15" Margin="14,5,14,5" Padding="15" BorderBrush="#555555" BorderThickness="1">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                    <CheckBox Name="ChkHideOnCopy" IsChecked="{Binding HideOnCopy}" Content="{Binding Loc[HideOnCopy]}" Foreground="White" Margin="0,0,25,0"/>
                    <CheckBox Name="ChkStartWithWindows" IsChecked="{Binding StartWithWindows}" Content="{Binding Loc[StartWithWindows]}" Foreground="White"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtShortcutLabel" Text="{Binding Loc[ShortcutKey]}" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#D92D2D2D" CornerRadius="8" BorderBrush="#555555" BorderThickness="1" Padding="10,5">
                        <TextBox x:Name="TxtHotkeyCapture" Background="Transparent" Foreground="#E0E0E0"
                                 BorderThickness="0" Width="160" IsReadOnly="True" CaretBrush="Transparent"
                                 Cursor="Hand" VerticalAlignment="Center" TextAlignment="Center"
                                 GotFocus="TxtHotkeyCapture_GotFocus"
                                 LostFocus="TxtHotkeyCapture_LostFocus"
                                 PreviewKeyDown="TxtHotkeyCapture_PreviewKeyDown"/>
                    </Border>
                </StackPanel>
                <TextBlock x:Name="TxtQuickPasteHint" Foreground="#777777" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtLanguageLabel" Text="{Binding Loc[Language]}" Foreground="White" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbLanguage" Width="100" Margin="5,0,0,0" SelectedIndex="{Binding LanguageIndex}">
                        <ComboBoxItem Content="English"/>
                        <ComboBoxItem Content="Türkçe"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtVersionLabel" Text="{Binding Loc[Version]}" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtVersionValue" Text="{Binding VersionText}" Foreground="#B9BBBE" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="BtnCheckUpdate" Command="{Binding CheckUpdatesCommand}" Content="{Binding Loc[CheckUpdates]}"
                            Background="#CC5865F2" Foreground="White" BorderBrush="#7289DA" BorderThickness="1"
                            Padding="12,4" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="TxtUpdateStatus" Text="{Binding UpdateStatus}" Foreground="#777777" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>